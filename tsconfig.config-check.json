{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Preserve",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "types": ["bun"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "noUncheckedIndexedAccess": false,
    "verbatimModuleSyntax": false,
    "baseUrl": "."
  },
  "include": [
    "packages/config-protocol/**/*.ts",
    "packages/config-engine/**/*.ts",
    "packages/config-adapters/**/*.ts",
    "packages/config-service/**/*.ts"
  ],
  "exclude": ["node_modules", "packages/*/node_modules"]
}
